// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  password      String
  gender        String?
  dateOfBirth   DateTime?
  phone         String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  iOweMoney     IOweMoney[]
  iAmOwedMoney  IAmOwedMoney[]
  otps          OTP[]

  @@map("users")
}

model OTP {
  id            String     @id @default(cuid())
  email         String
  otp           String
  type          String     @default("email_verification") // email_verification, password_reset
  isUsed        Boolean    @default(false)
  userId        String?
  user          User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt     DateTime
  createdAt     DateTime   @default(now())

  @@index([email])
  @@index([userId])
  @@map("otps")
}

model IOweMoney {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  personName    String
  amount        Float      // Original amount owed (immutable)
  date          DateTime
  dueDate       DateTime?
  phoneNumber   String?
  billImageUrl  String?
  description   String?
  status        String     @default("pending") // pending, completed
  
  payments      Payment[]  @relation("IOweMoneyPayments")
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
  @@map("i_owe_money")
}

model IAmOwedMoney {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  personName    String
  amount        Float      // Original amount owed (immutable)
  date          DateTime
  dueDate       DateTime?
  phoneNumber   String?
  billImageUrl  String?
  description   String?
  status        String     @default("pending") // pending, completed
  
  payments      Payment[]  @relation("IAmOwedMoneyPayments")
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
  @@map("i_am_owed_money")
}

model Payment {
  id                  String     @id @default(cuid())
  
  // Relations
  iOweMoneyId         String?
  iOweMoney           IOweMoney? @relation("IOweMoneyPayments", fields: [iOweMoneyId], references: [id], onDelete: Cascade)
  
  iAmOwedMoneyId      String?
  iAmOwedMoney        IAmOwedMoney? @relation("IAmOwedMoneyPayments", fields: [iAmOwedMoneyId], references: [id], onDelete: Cascade)
  
  // Payment details
  amount              Float
  type                String     @default("payment") // "payment" (money returned/paid), "additional_debt" (more money taken/owed)
  date                DateTime   @default(now())
  description         String?
  imageUrl            String?
  
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([iOweMoneyId])
  @@index([iAmOwedMoneyId])
  @@map("payments")
}
