// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  password      String
  gender        String?
  dateOfBirth   DateTime?
  phone         String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  iOweMoney     IOweMoney[]
  iAmOwedMoney  IAmOwedMoney[]

  @@map("users")
}

model IOweMoney {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  personName    String
  amount        Float
  date          DateTime
  dueDate       DateTime?
  phoneNumber   String?
  billImageUrl  String?
  description   String?
  status        String     @default("pending") // pending, completed
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
  @@map("i_owe_money")
}

model IAmOwedMoney {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  personName    String
  amount        Float
  date          DateTime
  dueDate       DateTime?
  phoneNumber   String?
  billImageUrl  String?
  description   String?
  status        String     @default("pending") // pending, completed
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
  @@map("i_am_owed_money")
}
